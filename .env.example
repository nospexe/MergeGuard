# ── Ollama (Local LLM)
OLLAMA_HOST=http://localhost:11434

# The model to use for all LLM agents
OLLAMA_MODEL=deepseek-coder

# ── Backend Server 
BACKEND_PORT=8000

# ── Frontend 
# Vite dev server origin — used by FastAPI CORS middleware
ALLOWED_ORIGINS=http://localhost:5173

# ── Analysis Settings
CORE_DIRS=src,backend,api,auth

# ── Demo Mode
DEMO_MODE=false
DEMO_FIXTURES_DIR=demo_fixtures