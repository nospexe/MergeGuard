# MergeGuard Environment Variables
# Copy this file to .env.local and fill in your values

# ── Convex (optional — app works in demo mode without it) ──
# Get your Convex URL from: npx convex dev
NEXT_PUBLIC_CONVEX_URL=

# ── Backend API (optional — app works in demo mode without it) ──
# Only needed if you're running the Python backend locally
NEXT_PUBLIC_BACKEND_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
